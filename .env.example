# Required — LLM and web search
OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key

# Optional — Custom LLM endpoint (OpenRouter, Azure, etc.)
# OPENAI_API_BASE=https://openrouter.ai/api/v1

# Optional — YouTube API enrichment (system works without this)
YOUTUBE_API_KEY=

# LLM model
MODEL_NAME=gpt-4o-mini
